#!/usr/bin/env bash
FILE=$(realpath "$1")
SOCK=/tmp/nvim-zopen.sock

# Check if the server is alive by running a trivial remote expression.
# If it fails, the socket doesn't exist or the server has died — start a new one.
if ! nvim --server "$SOCK" --remote-expr '1' 2>/dev/null; then
    nvim --listen "$SOCK" --headless > /dev/null 2>&1 &
    # Wait for the socket to become available
    until nvim --server "$SOCK" --remote-expr '1' 2>/dev/null; do
        sleep 0.1
    done
fi

# Open the file in the persistent server
nvim --server "$SOCK" --remote "$FILE"

# Wait until the server confirms the file is the active buffer
until nvim --server "$SOCK" --remote-expr "bufname('%') =~ '$(basename "$FILE")'" 2>/dev/null | grep -q '1'; do
    sleep 0.1
done

# Trigger markdown preview in the server (uses your existing <localleader>p mapping)
nvim --server "$SOCK" --remote-send '<Esc>:MarkdownPreviewToggle<CR>'

# Open a new zellij tab in the named session, attach to the persistent server as a UI, close the tab when done
zellij action new-tab -- bash -c "nvim --server '$SOCK' --remote-ui; zellij action close-pane"

# Give zellij a moment to open the tab before toggling fullscreen
sleep 0.3
zellij action toggle-fullscreen

exit 0
